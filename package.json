{
    "name": "nullbyte",
    "productName": "NullByte",
    "version": "0.5.0-alpha",
    "description": "NullByte - AI Coding Assistant powered by Gemini",
    "keywords": [
        "electron",
        "ai-assistant",
        "coding-tool",
