    },
    "homepage": "https://github.com/101yogeshsharma/NullByte#readme",
    "bugs": {
        "url": "https://github.com/101yogeshsharma/NullByte/issues"
    },
    "dependencies": {
        "@google/generative-ai": "^0.21.0"
    },
    "devDependencies": {
        "electron": "^31.0.0",
        "electron-builder": "^26.7.0"
    },
}
}